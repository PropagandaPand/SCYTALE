{
  "name": "scytale",
  "version": "0.0.1",
  "description": "Ende-zu-Ende verschlüsselter Messenger als PWA — gegen Massenüberwachung.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "cf:dev": "wrangler dev",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "hash-wasm": "^4.12.0",
    "idb": "^8.0.1"
  }
}
