# Skip package install scripts. wrangler pulls in miniflare -> sharp, whose
# native build script fails on some platforms/CI images. We never use sharp
# (it's only miniflare's Images-binding emulation), and every real dependency
# (esbuild, workerd, libsodium, hash-wasm) ships its binaries via
# optionalDependencies, not install scripts — so skipping scripts is safe and
# makes `npm install` work locally and in Cloudflare Workers Builds alike.
ignore-scripts=true
